import pandas as pd
import numpy as np
from sklearn.svm import SVC
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import precision_score, recall_score, accuracy_score, f1_score, confusion_matrix
import matplotlib.pyplot as plt
import seaborn as sns

# read dataset
data = pd.read_csv("play_golf_svm.csv", header=None)

# convert horizontal dataset to vertical
data = data.set_index(0).T
data.columns = ["Outlook","Temperature","Humidity","Windy","Play"]

# encode categorical data
le = LabelEncoder()
for col in data.columns:
    data[col] = le.fit_transform(data[col])

X = data[["Outlook","Temperature","Humidity","Windy"]]
y = data["Play"]

# SVM model
model = SVC(kernel="linear")
model.fit(X,y)

# prediction
y_pred = model.predict(X)

# evaluation metrics
print("Accuracy:", accuracy_score(y,y_pred))
print("Precision:", precision_score(y,y_pred))
print("Recall:", recall_score(y,y_pred))
print("F1 Score:", f1_score(y,y_pred))

# confusion matrix
cm = confusion_matrix(y,y_pred)

plt.figure(figsize=(6,4))
sns.heatmap(cm, annot=True, fmt="d", cmap="Blues")
plt.xlabel("Predicted")
plt.ylabel("Actual")
plt.title("Confusion Matrix - SVM")
plt.show()


Problem Understanding & Aim
To predict whether the player will play golf using Temperature, Humidity and Wind using SVM classifier.

Data Collection & Pre-Processing
Dataset contains Outlook, Temperature, Humidity, Windy and Play Golf. Categorical values are converted into numerical form.

Model Design / Algorithm Selection
Support Vector Machine classifier is used for classification.

